# ANDRAX 2.0 app — release signing credentials (LOCAL DEVELOPERS).
#
# Copy this file to `keystore.properties` (which is git-ignored) and fill in
# your release keystore details. build.gradle.kts reads it when signing the
# release build. In CI, the same values are supplied via environment variables
# instead — see docs/dev/05-signing-pipeline.md.
#
#   cp keystore.properties.example keystore.properties
#
storeFile=/absolute/path/to/andrax-release.keystore
storePassword=changeme
keyAlias=andrax
keyPassword=changeme
