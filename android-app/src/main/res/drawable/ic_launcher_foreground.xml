<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: a crosshair glyph inside the 72dp safe zone of the
  108dp canvas. All-vector so no binary PNG assets are needed (minSdk 26 means
  every supported device uses adaptive icons).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer ring -->
    <path
        android:strokeColor="@color/andrax_accent"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:pathData="M54,30 a24,24 0 1,0 0.01,0 Z" />

    <!-- Crosshair ticks -->
    <path
        android:strokeColor="@color/andrax_accent"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M54,22 L54,38 M54,70 L54,86 M22,54 L38,54 M70,54 L86,54" />

    <!-- Center dot -->
    <path
        android:fillColor="@color/andrax_accent"
        android:pathData="M54,50 a4,4 0 1,0 0.01,0 Z" />
</vector>
