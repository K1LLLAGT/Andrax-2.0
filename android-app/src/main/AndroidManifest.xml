<?xml version="1.0" encoding="utf-8"?>
<!--
  ANDRAX 2.0 companion app manifest.
  The app is a front-end only. It launches Termux backend scripts via Termux's
  RUN_COMMAND intent; it performs no privileged operations itself.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The application id / namespace comes from build.gradle.kts (AGP 8+
         no longer allows a package attribute here). -->

    <!-- Required to send RUN_COMMAND intents to Termux. -->
    <uses-permission android:name="com.termux.permission.RUN_COMMAND" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 11+ package visibility: we need to see the Termux package. -->
    <queries>
        <package android:name="com.termux" />
    </queries>

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.Andrax">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.CategoryListActivity" android:exported="false" />
        <activity android:name=".ui.ToolListActivity"     android:exported="false" />
        <activity android:name=".ui.ToolDetailActivity"   android:exported="false" />
    </application>
</manifest>
